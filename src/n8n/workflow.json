          {"node": "HTTP Request SerpAPI 3", "type": "main", "index": 0}
        ]
      ]
    },
    "HTTP Request SerpAPI 1": {"main": [[{"node": "Merge", "type": "main", "index": 0}]]},
    "HTTP Request SerpAPI 2": {"main": [[{"node": "Merge", "type": "main", "index": 1}]]},
    "HTTP Request SerpAPI 3": {"main": [[{"node": "Merge", "type": "main", "index": 2}]]},
