{
  "name": "DMSW TikTok Pipeline",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 24
            }
          ]
        }
      },
      "id": "scheduleTrigger",
      "name": "ScheduleTrigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [200, 300]
    },
    {
      "parameters": {
        "url": "https://serpapi.com/search.json",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {"name": "api_key", "value": "={{$env.SERPAPI_KEY}}"},
            {"name": "q", "value": "tendances marketing digital france entrepreneurs"},
            {"name": "gl", "value": "fr"},
            {"name": "hl", "value": "fr"},
            {"name": "num", "value": "5"}
          ]
        }
      },
      "id": "serpApiTrendsX3",
      "name": "SerpAPITrendsX3",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [450, 300]
    },
    {
      "parameters": {
        "mode": "raw",
        "jsonOutput": "={{ {\"trends\": $json.organic_results || []} }}"
      },
      "id": "mergeTrends",
      "name": "MergeTrends",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [700, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "x-api-key", "value": "={{$env.ANTHROPIC_API_KEY}}"},
            {"name": "anthropic-version", "value": "2023-06-01"},
            {"name": "content-type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\"model\":\"claude-sonnet-4-20250514\",\"max_tokens\":2000,\"system\":\"Tu es un expert en contenu TikTok viral pour le marché français.\",\"messages\":[{\"role\":\"user\",\"content\":\"Tendances: \" + JSON.stringify($json.trends)}]} }}"
      },
      "id": "claudeGenerateScripts",
      "name": "ClaudeGenerateScripts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [950, 300]
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.content?.[0]?.text || '[]';\nconst scripts = JSON.parse(raw);\nreturn scripts.map((script) => ({json: script}));"
      },
      "id": "split3Scripts",
      "name": "Split3Scripts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 300]
    },
    {
      "parameters": {
        "resource": "page",
        "operation": "create",
        "databaseId": "={{$env.NOTION_DATABASE_ID}}",
        "propertiesUi": {
          "propertyValues": [
            {"key": "Name", "title": "={{$json.hook}}"},
            {"key": "Script", "richText": "={{$json.script}}"},
            {"key": "CTA", "richText": "={{$json.cta}}"}
          ]
        }
      },
      "id": "notionCreatePages",
      "name": "NotionCreatePages",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2.2,
      "position": [1450, 220],
      "credentials": {
        "notionApi": {
          "id": "NOTION_CREDENTIAL_ID",
          "name": "Notion Placeholder"
        }
      }
    },
    {
      "parameters": {
        "command": "npm run pipeline"
      },
      "id": "remotionRenderVideo",
      "name": "RemotionRenderVideo",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [1450, 380]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.bufferapp.com/1/updates/create.json",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "Authorization", "value": "=Bearer {{$env.BUFFER_ACCESS_TOKEN}}"},
            {"name": "Content-Type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\"profile_ids\":[$env.BUFFER_PROFILE_ID],\"text\":\"DMSW TikTok auto-publish\",\"scheduled_at\":$now.plus({hours:24}).toISO()} }}"
      },
      "id": "bufferSchedulePlus24h",
      "name": "BufferSchedulePlus24h",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1700, 380]
    },
    {
      "parameters": {
        "sendTo": "team@placeholder.local",
        "subject": "DMSW TikTok Pipeline - Résumé",
        "emailType": "text",
        "message": "={{'Pipeline exécuté. Résultat Buffer: ' + JSON.stringify($json)}}"
      },
      "id": "gmailSummary",
      "name": "GmailSummary",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [1950, 380],
      "credentials": {
        "gmailOAuth2": {
          "id": "GMAIL_CREDENTIAL_ID",
          "name": "Gmail Placeholder"
        }
      }
    }
  ],
  "connections": {
    "ScheduleTrigger": {
      "main": [[{"node": "SerpAPITrendsX3", "type": "main", "index": 0}]]
    },
    "SerpAPITrendsX3": {
      "main": [[{"node": "MergeTrends", "type": "main", "index": 0}]]
    },
    "MergeTrends": {
      "main": [[{"node": "ClaudeGenerateScripts", "type": "main", "index": 0}]]
    },
    "ClaudeGenerateScripts": {
      "main": [[{"node": "Split3Scripts", "type": "main", "index": 0}]]
    },
    "Split3Scripts": {
      "main": [
        [{"node": "NotionCreatePages", "type": "main", "index": 0}],
        [{"node": "RemotionRenderVideo", "type": "main", "index": 0}]
      ]
    },
    "RemotionRenderVideo": {
      "main": [[{"node": "BufferSchedulePlus24h", "type": "main", "index": 0}]]
    },
    "NotionCreatePages": {
      "main": [[{"node": "GmailSummary", "type": "main", "index": 0}]]
    },
    "BufferSchedulePlus24h": {
      "main": [[{"node": "GmailSummary", "type": "main", "index": 0}]]
    }
  },
  "active": false,
  "settings": {},
  "versionId": "1"
}
{
