        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "x-api-key", "value": "={{$env.ANTHROPIC_API_KEY}}"},
            {"name": "anthropic-version", "value": "2023-06-01"},
            {"name": "content-type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"model\":\"claude-sonnet-4-20250514\",\"max_tokens\":2000,\"system\":\"Tu es un expert en contenu TikTok viral pour le marché français.\\nTu travailles pour DMSW, une agence web ciblant les entrepreneurs solo.\\nLes vidéos ne montrent jamais de visage : texte animé, screen recording ou voix off uniquement.\\n\\nÀ partir des tendances fournies, génère exactement 3 scripts TikTok percutants.\\n\\nRetourne UNIQUEMENT ce tableau JSON valide, sans markdown ni texte autour :\\n[\\n  {\\n    \\\"id\\\": 1,\\n    \\\"hook\\\": \\\"accroche choc en moins de 8 mots\\\",\\n    \\\"angle\\\": \\\"education | coulisses | opinion\\\",\\n    \\\"format\\\": \\\"texte_anime | screen_recording | voix_off\\\",\\n    \\\"script\\\": \\\"script complet mot pour mot, 30 à 60 secondes parlé\\\",\\n    \\\"visuels\\\": \\\"description précise de ce qu'on voit à l'écran\\\",\\n    \\\"cta\\\": \\\"appel à l'action final\\\",\\n    \\\"hashtags\\\": [\\\"#tag1\\\",\\\"#tag2\\\",\\\"#tag3\\\",\\\"#tag4\\\",\\\"#tag5\\\"],\\n    \\\"duree_secondes\\\": 45\\n  }\\n]\",\"messages\":[{\"role\":\"user\",\"content\":\"Tendances agrégées: {{$json}}\"}]}"
      },
      "id": "claude_request",
      "name": "HTTP Request Claude",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [780, 300]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const raw = $json.content?.[0]?.text ?? '[]';\nconst scripts = JSON.parse(raw);\nreturn scripts.map((s) => ({ json: s }));"
      },
      "id": "code_split",
      "name": "Code Parse & Split",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1000, 300]
    },
    {
      "parameters": {
        "resource": "page",
        "operation": "create",
        "databaseId": "={{$env.NOTION_DATABASE_ID}}",
        "title": "={{$json.hook}}",
        "propertiesUi": {
          "propertyValues": [
            {"key": "hook", "title": "Hook", "textContent": "={{$json.hook}}"},
            {"key": "angle", "title": "Angle", "textContent": "={{$json.angle}}"},
            {"key": "format", "title": "Format", "textContent": "={{$json.format}}"},
            {"key": "script", "title": "Script", "textContent": "={{$json.script}}"}
          ]
        }
      },
      "id": "notion_create",
      "name": "Notion",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2.2,
      "position": [1220, 220],
      "credentials": {
        "notionApi": {
          "id": "notion_placeholder",
          "name": "Notion account"
        }
      }
    },
    {
      "parameters": {
        "command": "cd {{$env.PROJECT_ROOT}} && npx ts-node src/scripts/renderVideo.ts"
      },
      "id": "exec_render",
      "name": "Execute Command",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [1220, 380]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.bufferapp.com/1/updates/create.json",
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {
          "parameters": [
            {"name": "access_token", "value": "={{$env.BUFFER_ACCESS_TOKEN}}"},
            {"name": "profile_ids[]", "value": "YOUR_BUFFER_PROFILE_ID"},
            {"name": "text", "value": "={{$json.hook + ' ' + ($json.hashtags || []).join(' ')}}"},
            {"name": "media[video]", "value": "https://example.com/video.mp4"},
            {"name": "scheduled_at", "value": "={{new Date(Date.now() + 24*60*60*1000).toISOString()}}"}
          ]
        }
      },
      "id": "buffer_publish",
      "name": "HTTP Request Buffer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1440, 300]
    },
    {
      "parameters": {
        "sendTo": "={{$env.GMAIL_USER}}",
        "subject": "DMSW TikTok - Résumé du jour",
        "emailType": "text",
        "message": "={{'Hooks générés:\\n' + $items('Code Parse & Split').map(i => '- ' + i.json.hook).join('\\n')}}"
      },
      "id": "gmail_summary",
      "name": "Gmail",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [1660, 300],
      "credentials": {
        "gmailOAuth2": {
          "id": "gmail_placeholder",
          "name": "Gmail account"
        }
      }
    }
  ],
  "connections": {
