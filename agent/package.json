{
  "name": "dmsw-tiktok-agent",
  "version": "1.0.0",
  "description": "Agent IA autonome — génération de scripts TikTok DMSW",
  "type": "module",
  "scripts": {
    "dev":       "tsx watch src/index.ts",
    "generate":  "AGENT_MODE=standalone tsx src/index.ts",
    "build":     "tsc",
    "start":     "node dist/index.js",
    "server":    "tsx src/index.ts --server"
  },
  "dependencies": {
    "@anthropic-ai/sdk":  "^0.52.0",
    "@notionhq/client":   "^2.2.15",
    "dotenv":             "^16.4.1",
    "express":            "^4.18.2",
    "nodemailer":         "^6.9.8"
  },
  "devDependencies": {
    "@types/express":     "^4.17.21",
    "@types/node":        "^20.11.0",
    "@types/nodemailer":  "^6.4.14",
    "tsx":                "^4.7.0",
    "typescript":         "^5.3.3"
  }
}
