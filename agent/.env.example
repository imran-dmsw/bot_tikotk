# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── SerpAPI ─────────────────────────────────────────────────────────────────
SERPAPI_KEY=...

# ─── Notion ──────────────────────────────────────────────────────────────────
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail : activer "Mots de passe d'application" dans votre compte Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@dmsw.fr
SMTP_PASS=xxxx xxxx xxxx xxxx    # mot de passe d'application Google
GMAIL_TO=contact@dmsw.fr

# ─── Remotion ────────────────────────────────────────────────────────────────
REMOTION_DIR=../remotion          # chemin relatif depuis /agent
REMOTION_OUT=../output
# Optionnel : webhook externe pour déclencher le render à distance
# RENDER_WEBHOOK=http://localhost:3200/render

# ─── Serveur agent ────────────────────────────────────────────────────────────
AGENT_PORT=3100
